
# Get External IP / Internet Speed
alias myip="curl https://ipinfo.io/json" # or /ip for plain-text ip
alias speedtest="curl -s https://raw.githubusercontent.com/sivel/speedtest-cli/master/speedtest.py | python -"

# Quickly serve the current directory as HTTP
alias serve='ruby -run -e httpd . -p 8000' # Or python -m SimpleHTTPServer :)

# NOTE: On Q3 2021, Le Wagon decided to change the Web Dev curriculum default text editor
alias stt="echo 'Launching VS Code instead of Sublime Text... (cf ~/.aliases)' && code ."

# clear Terminal
alias c=clear

alias push="git add . && git commit -m "solution" && git push origin master && git status"
alias update="sudo apt-get update && sudo apt-get upgrade"
alias install="sudo apt install"
alias ll.="ls -la -d .* --color=auto"
alias cd..="cd .."
alias ..="cd .."
alias ...="cd ../../"
alias ....="cd ../../../"
alias mkdir='mkdir -pv'
alias diff='colordiff'
